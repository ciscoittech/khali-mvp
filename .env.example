# OpenRouter (required — powers DeepSeek V4 Flash + Veo 3.1 Lite)
OPENROUTER_API_KEY=sk-or-your-key-here

# Telegram Bot (for cousin's access)
TELEGRAM_BOT_TOKEN=your-bot-token

# Email channel (cousin's email — receives trend alerts)
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_ADDRESS=cousin@gmail.com
EMAIL_PASSWORD=app-password-here
